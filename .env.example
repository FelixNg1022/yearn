OPENROUTER_API_KEY=            # https://openrouter.ai/keys
PROJECT_ID=                    # Photon project id (https://photon.codes dashboard)
PROJECT_SECRET=                # Photon project secret (paired with PROJECT_ID)
TURSO_DATABASE_URL=            # libsql://<db-name>-<org>.turso.io   (or file:./yun.db for local)
TURSO_AUTH_TOKEN=              # turso db tokens create <db-name>
BIRTH_ENCRYPTION_KEY=          # 32-byte AES key: openssl rand -base64 32
FOLLOW_UP_DAYS=5               # fallback only — used when the question has no extractable time horizon
FOLLOW_UP_BUFFER_DAYS=1        # extra days after the predicted event before we ask how it played out
USE_LLM_HORIZON_FALLBACK=true  # if heuristic finds no horizon, ask Claude for one (set "false" to disable)
DEMO_FOLLOW_UP_SECONDS=        # unset in prod; set to e.g. 30 for demo (hard override of everything above)
SCHEDULER_INTERVAL_SECONDS=60
RATE_LIMIT_PER_DAY=10
LOG_LEVEL=info
NODE_ENV=development
